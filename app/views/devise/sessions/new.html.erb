<div class="devise-page">
  <div class="devise-card">
    <div class="devise-card__header">
      <h2><%= t('.sign_in', :default => "Sign in") %></h2>
    </div>
    <div class="devise-card__body">
      <%= form_for(resource, as: resource_name, url: session_path(resource_name), html: { role: "form" }) do |f| %>
        <div class="devise-field">
          <%= f.label :email %>
          <%= f.email_field :email, autofocus: true %>
        </div>
        <div class="devise-field">
          <%= f.label :password %>
          <%= f.password_field :password, autocomplete: "off" %>
        </div>
        <% if devise_mapping.rememberable? %>
          <div class="devise-remember">
            <%= f.check_box :remember_me %>
            <%= f.label :remember_me, t('.remember_me', :default => "Remember me") %>
          </div>
        <% end %>
        <%= f.submit t('.sign_in', :default => "Sign in"), class: "devise-submit" %>
      <% end %>
    </div>
    <div class="devise-card__footer">
      <%= render "devise/shared/links" %>
    </div>
  </div>
</div>
