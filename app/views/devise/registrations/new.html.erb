<div class="devise-page">
  <div class="devise-card">
    <div class="devise-card__header">
      <h2><%= t('.sign_up', :default => "Sign up") %></h2>
    </div>
    <div class="devise-card__body">
      <%= form_for(resource, :as => resource_name, :url => registration_path(resource_name), html: { role: "form" }) do |f| %>
        <div class="devise-field">
          <%= f.label :email %>
          <%= f.email_field :email, autofocus: true %>
        </div>
        <div class="devise-field">
          <%= f.label :first_name %>
          <%= f.text_field :first_name %>
        </div>
        <div class="devise-field">
          <%= f.label :last_name %>
          <%= f.text_field :last_name %>
        </div>
        <div class="devise-field">
          <%= f.label :phone %>
          <%= f.text_field :phone %>
        </div>
        <div class="devise-field">
          <%= f.label :password %>
          <%= f.password_field :password %>
        </div>
        <div class="devise-field">
          <%= f.label :password_confirmation %>
          <%= f.password_field :password_confirmation %>
        </div>
        <%= f.submit t('.sign_up', :default => "Sign up"), class: "devise-submit" %>
      <% end %>
    </div>
    <div class="devise-card__footer">
      <%= render "devise/shared/links" %>
    </div>
  </div>
</div>
